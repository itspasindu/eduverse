# Copy to backend/.env and fill in your keys (the app loads this file automatically).

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Optional: auto-apply lesson migrations on backend startup (Dashboard -> Database -> password)
SUPABASE_DB_PASSWORD=
# Or full URI: SUPABASE_DB_URL=postgresql://postgres.[ref]:[PASSWORD]@...pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=

FAL_KEY=your-fal-key
FAL_MOCK_MODE=false
FAL_MEME_MODEL=fal-ai/flux/schnell
FAL_IMAGE_MODEL=fal-ai/flux/schnell
FAL_VIDEO_MODEL=fal-ai/minimax/hailuo-02/standard/image-to-video
FAL_VISION_MODEL=fal-ai/florence-2-large/caption
FAL_TTS_MODEL=fal-ai/minimax/speech-02-hd
FAL_CHARACTER_MODEL=fal-ai/flux/schnell
FAL_LLM_ENDPOINT=fal-ai/any-llm
FAL_LLM_MODEL=google/gemini-2.0-flash-001
FAL_LLM_MAX_TOKENS=1024
FAL_REQUEST_TIMEOUT=120
FAL_LESSON_WORKFLOW_ID=

# development | production
ENVIRONMENT=development
# Required in production for /health/db (send as X-Health-Token header)
HEALTH_DB_TOKEN=

# Rate limits
RATE_LIMIT_AI_PER_HOUR=30
RATE_LIMIT_AUTH_PER_MINUTE=15
AI_DAILY_CAP_STUDENT=50
AI_DAILY_CAP_CREATOR=200
MAX_REQUEST_BODY_BYTES=2097152

# Comma-separated HTTPS hosts for post/avatar URLs
ALLOWED_URL_HOSTS=picsum.photos,fal.media,fal.run

# CORS_ORIGINS=http://localhost:3000

# Public URLs (PayHere notify/return hit the backend; return redirects to frontend)
API_PUBLIC_URL=http://localhost:8000
FRONTEND_PUBLIC_URL=http://localhost:3000

# PayHere sandbox — https://sandbox.payhere.lk → Integrations
PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_SANDBOX=true
PAYHERE_CURRENCY=USD

# Lesson features (stored on disk — no Supabase tables)
# LESSON_DATA_DIR=backend/data/lessons
# Animated clips + merge voice into MP4 (requires ffmpeg installed on PATH)
LESSON_ENABLE_VIDEO_CLIPS=true
LESSON_MUX_VOICE_INTO_VIDEO=true
LESSON_VIDEO_TIMEOUT=180
# Target length of the single combined lesson video (seconds, default ~90 = 1.5 min)
LESSON_SCENE_TARGET_SECONDS=90

AGENT_MAX_TURNS=6
SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
SERPER_API_KEY=
