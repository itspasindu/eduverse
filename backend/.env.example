SUPABASE_URL=https://your-project.supabase.co
# Public anon key (safe for frontend). JWT usually starts with eyJ...
SUPABASE_ANON_KEY=your-anon-public-key
# Service role — backend only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

FAL_KEY=your-fal-key
FAL_MOCK_MODE=false

# Optional: extra frontend origins (comma-separated)
# CORS_ORIGINS=http://localhost:3000,http://172.20.192.1:3000
